{
  "name": "gosta-assignemnt",
  "private": true,
  "scripts": {
    "start": "turbo build && node packages/backend/dist/index.js",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "db:migrate": "kysely migrate:latest --cwd packages/backend",
    "db:new": "kysely migrate:make --cwd packages/backend"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "kysely": "0.28.14"
  }
}